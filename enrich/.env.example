# Copy to .env (gitignored) and fill in real values, or set these directly
# in the outer docker-compose.yml's `environment:` block for the
# nrd-enrich service. Never commit real values here.

# VirusTotal API key. Absent/empty = the vt phase makes zero requests and
# every domain is marked vt_status=no_api_key.
VT_API_KEY=

# Reverse WHOIS has no free/self-hosted source. These are unused stubs
# reserved for a future paid provider (e.g. WhoisXML, SecurityTrails,
# DomainTools) -- setting them today does nothing.
REVERSE_WHOIS_PROVIDER=
REVERSE_WHOIS_API_KEY=
